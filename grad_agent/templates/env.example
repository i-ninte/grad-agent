# Secrets only. Copy to ~/.grad-agent/.env and fill in.

# Required for the hook synthesiser + verifier.
ANTHROPIC_API_KEY=

# SMTP for the review-mailer. Gmail App Password recommended.
# Presets:
#   Gmail:      smtp.gmail.com          587   (App Password: myaccount.google.com/apppasswords)
#   Outlook:    smtp-mail.outlook.com   587
#   Yahoo:      smtp.mail.yahoo.com     587   (App Password required)
#   Zoho:       smtp.zoho.com           587
#   Fastmail:   smtp.fastmail.com       587   (App Password required)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Optional: read-only IMAP so the agent auto-detects professor replies and
# tags the outreach log. Defaults to Gmail + your SMTP credentials.
# The agent never sends, deletes, or marks messages via IMAP.
# IMAP_SERVER=imap.gmail.com     # Outlook: outlook.office365.com, Yahoo: imap.mail.yahoo.com
# IMAP_USERNAME=
# IMAP_PASSWORD=

# Optional: free Semantic Scholar API key for a dedicated rate-limit pool.
# Request at https://www.semanticscholar.org/product/api
S2_API_KEY=

# Optional: sync more projects from GitHub + HuggingFace.
GITHUB_USERNAME=
GITHUB_TOKEN=
HF_USERNAME=
HF_TOKEN=

# Optional: portfolio blog plugin (only if blog.enabled: true in profile.yaml).
# PORTFOLIO_BASE_URL=
# PORTFOLIO_ADMIN_PASSWORD=
